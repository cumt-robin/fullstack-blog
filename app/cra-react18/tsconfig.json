{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "strict": true,
        "moduleResolution": "node",
        "allowJs": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },
        "types": ["jest", "@testing-library/jest-dom"],
        "lib": ["esnext", "dom", "dom.iterable"],
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "moduleDetection": "force"
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
