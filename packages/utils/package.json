{
  "name": "@fullstack-blog/utils",
  "version": "0.0.2",
  "description": "Utility functions for fullstack blog",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "echo \"No build needed for utils package\"",
    "test": "jest --config jest.config.js",
    "test:dom": "jest --config jest.dom.config.js",
    "test:watch": "jest --watch",
    "test:watch:dom": "jest --watch --config jest.dom.config.js",
    "test:watch:all": "pnpm test:watch && pnpm test:watch:dom",
    "test:cov": "jest --coverage --config jest.config.js",
    "test:cov:dom": "jest --coverage --config jest.dom.config.js",
    "test:cov:all": "pnpm test:cov && pnpm test:cov:dom"
  },
  "keywords": [
    "utils",
    "fullstack",
    "blog"
  ],
  "author": "Tusi",
  "license": "MIT",
  "dependencies": {
    "bezier-easing": "^2.1.0",
    "dayjs": "^1.11.19",
    "lodash-es": "^4.17.21",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@fullstack-blog/eslint-config": "workspace:^",
    "@fullstack-blog/types": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "29",
    "jsdom": "^28.1.0",
    "lodash": "^4.17.21",
    "ts-jest": "^29.1.0"
  }
}
